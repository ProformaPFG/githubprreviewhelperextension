{
  "manifest_version": 3,
  "name": "GitHub Code Review Assistant",
  "version": "1.0.0",
  "description": "Automated code analysis for GitHub PRs. Detects 76 security and quality issues.",
  
  "permissions": [
    "activeTab",
    "storage"
  ],
  
  "host_permissions": [
    "https://github.com/*/*/pull/*/files*",
    "https://github.com/*/*/pull/*/changes*",
    "https://*.github.com/*/*/pull/*/files*",
    "https://*.github.com/*/*/pull/*/changes*"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "GitHub Code Review Assistant"
  },
  
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/*/pull/*/files*",
        "https://github.com/*/*/pull/*/changes*",
        "https://*.github.com/*/*/pull/*/files*",
        "https://*.github.com/*/*/pull/*/changes*"
      ],
      "js": ["content.js"],
      "css": ["ui-styles.css"],
      "run_at": "document_end"
    }
  ],
  
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
